# Backend (see backend/README.md; for Docker Postgres use postgresql URL below)
# Production: use strong random SECRET_KEY and different DB credentials; do not use these example values.
DATABASE_URL=sqlite:///./workout_tracker.db
# For PostgreSQL with infra/docker-compose: postgresql://workout_user:workout_password@localhost:5432/workout_tracker
SECRET_KEY=change-this-secret-key-in-production
# CORS: comma-separated origins (e.g. http://localhost:5173,http://localhost:3000) or JSON array for production
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite; see frontend/README.md)
VITE_API_URL=http://localhost:8000
