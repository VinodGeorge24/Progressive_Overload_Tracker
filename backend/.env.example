# Backend environment (plan/coding_plan.md Slice 0). Copy to .env and adjust.
# Production: use strong random SECRET_KEY and different DB credentials; do not use these example values.
# For local SQLite (default):
# DATABASE_URL=sqlite:///./workout_tracker.db
# For PostgreSQL via infra/docker-compose:
DATABASE_URL=postgresql://workout_user:workout_password@localhost:5432/workout_tracker
SECRET_KEY=change-this-secret-key-in-production
# Optional: comma-separated CORS origins (defaults include localhost:3000, 5173). Production: set to your frontend origin(s).
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
